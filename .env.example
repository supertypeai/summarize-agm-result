# Use these when running with: --api openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

# Use these when running with: --api gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=
GEMINI_MODEL=gemini-2.5-flash

SUMMARY_CHUNK_CHARS=12000
SUMMARY_TEMPERATURE=0.2
OCR_LANG=eng
OCR_ENGINE=auto
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_VISION_MODEL=qwen/qwen3.6-plus
OPENROUTER_TIMEOUT_SEC=240
OPENROUTER_VISION_MAX_PAGES=40
OPENROUTER_MAX_IMAGE_BYTES=28000000
OPENROUTER_MAX_PAGES_PER_REQUEST=4
OPENROUTER_MAX_OUTPUT_TOKENS=12000
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=meeting-summarizer
IDX_PUBEX_QNA_KEYWORD=laporan hasil public expose
IDX_PUBEX_COMPANY_UPDATE_KEYWORD=materi public expose

# IDX fetch mode (used with --from-idx)
IDX_API_URL=https://www.idx.co.id/primary/NewsAnnouncement/GetAllAnnouncement
IDX_PAGE_URL=https://www.idx.co.id/id/perusahaan-tercatat/keterbukaan-informasi
IDX_KEYWORD=ringkasan risalah
IDX_SEEN_FILE=seen_announcements.json
IDX_LANG=id
IDX_PAGE_SIZE=20
IDX_VERIFY_SSL=true
IDX_PROXY_URL=

# Supabase upsert
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
PROXY_URL=your-proxy-url
