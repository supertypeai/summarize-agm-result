# Use these when running with: --api openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

# Use these when running with: --api gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=
GEMINI_MODEL=gemini-2.5-flash

SUMMARY_CHUNK_CHARS=12000
SUMMARY_TEMPERATURE=0.2
OCR_LANG=eng
OCR_ENGINE=auto

# IDX fetch mode (used with --from-idx)
IDX_API_URL=https://www.idx.co.id/primary/NewsAnnouncement/GetAllAnnouncement
IDX_PAGE_URL=https://www.idx.co.id/id/perusahaan-tercatat/keterbukaan-informasi
IDX_KEYWORD=ringkasan risalah
IDX_SEEN_FILE=seen_announcements.json
IDX_LANG=id
IDX_PAGE_SIZE=20
IDX_VERIFY_SSL=true
IDX_PROXY_URL=

# Supabase upsert
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
PROXY_URL=your-proxy-url